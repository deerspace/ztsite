# Commerce provider selection.
# With no vars set, the site runs in mock mode (typed in-repo catalog, localStorage cart).
# Setting NEXT_PUBLIC_WC_STORE_URL switches to the real WooCommerce Store API.

# Explicit override: "mock" | "woocommerce". Optional — presence of
# NEXT_PUBLIC_WC_STORE_URL implies woocommerce unless this says "mock".
# Use the NEXT_PUBLIC_ form so the override also reaches the browser cart client.
#NEXT_PUBLIC_COMMERCE_PROVIDER=woocommerce

# WordPress origin (no trailing slash). NEXT_PUBLIC_ because the cart client
# calls the Store API from the browser.
#NEXT_PUBLIC_WC_STORE_URL=https://www.zevtechnologies.com

# Where the checkout handoff lands. Defaults to ${NEXT_PUBLIC_WC_STORE_URL}/checkout/
#NEXT_PUBLIC_WC_CHECKOUT_URL=https://www.zevtechnologies.com/checkout/

# ISR window for catalog pages, seconds. Default 300.
#WC_REVALIDATE_SECONDS=300
